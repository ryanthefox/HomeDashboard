# Kopieer dit bestand naar .env en vul je eigen waarden in
# Het .env bestand wordt NOOIT naar Git gepusht

# Philips Hue
HUE_BRIDGE_IP=192.168.1.x
HUE_API_KEY=jouw-hue-api-sleutel

# LG ThinQ
LGTHINQ_PAT=jouw-personal-access-token
LGTHINQ_CLIENT_ID=jouw-client-uuid

# Optioneel — standaard Veenendaal
# WEATHER_LAT=52.0259
# WEATHER_LON=5.5553
# WEATHER_TZ=Europe/Amsterdam

# Optioneel — standaard NL / EIC endpoint
# LGTHINQ_COUNTRY=NL
# LGTHINQ_BASE_URL=https://api-eic.lgthinq.com
